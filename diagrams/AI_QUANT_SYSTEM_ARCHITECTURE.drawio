        <mxCell id="p3-edge-testnet-gateway" value="request / relay" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0369A1;fontSize=9;" edge="1" parent="p3-host" source="p3-testnet" target="p3-gateway-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-edge-cal-gateway" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0369A1;" edge="1" parent="p3-host" source="p3-cal" target="p3-gateway-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-edge-validation-gateway" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0369A1;" edge="1" parent="p3-host" source="p3-validation" target="p3-gateway-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-edge-live-gateway" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0369A1;" edge="1" parent="p3-host" source="p3-live" target="p3-gateway-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;strokeWidth=2;" edge="1" parent="p3-host" source="p3-testnet" target="p3-seal1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;strokeWidth=2;" edge="1" parent="p3-host" source="p3-seal1" target="p3-cal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;strokeWidth=2;" edge="1" parent="p3-host" source="p3-cal" target="p3-freeze"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;strokeWidth=2;" edge="1" parent="p3-host" source="p3-freeze" target="p3-validation"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#475569;strokeWidth=2;" edge="1" parent="p3-host" source="p3-validation" target="p3-seal2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#DC2626;strokeWidth=2;" edge="1" parent="p3-host" source="p3-seal2" target="p3-live"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-upgrade" value="实盘后两条发布路径：人工工程 C2/C3 + 月度白名单自动灰度" style="swimlane;html=1;rounded=1;startSize=40;fillColor=#FFF7ED;strokeColor=#EA580C;strokeWidth=2;fontStyle=1;fontSize=15;fontColor=#7C2D12;" vertex="1" parent="s1"><mxGeometry x="30" y="660" width="1180" height="360" as="geometry"/></mxCell>
        <mxCell id="p3-candidate" value="候选分类&lt;br&gt;工程变更 → 人工 C2/C3&lt;br&gt;白名单策略 → 月度自动流水线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=11;" vertex="1" parent="p3-upgrade"><mxGeometry x="45" y="90" width="190" height="90" as="geometry"/></mxCell>
        <mxCell id="p3-tempvps" value="&lt;b&gt;首选：临时 validation VPS&lt;/b&gt;&lt;br&gt;韩国同区域 · 同 OS/架构&lt;br&gt;cgroup 限制到等效 2 vCPU / 12 GiB / 约 200 GB&lt;br&gt;只持 Testnet key；Shadow 只读公开行情&lt;br&gt;无生产 key / DB / 卷 / 反向控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontSize=11;" vertex="1" parent="p3-upgrade"><mxGeometry x="285" y="55" width="330" height="160" as="geometry"/></mxCell>
        <mxCell id="p3-or" value="或" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FEF3C7;strokeColor=#D97706;fontStyle=1;fontSize=13;" vertex="1" parent="p3-upgrade"><mxGeometry x="650" y="105" width="50" height="50" as="geometry"/></mxCell>
        <mxCell id="p3-stoplive" value="&lt;b&gt;备选：原主机互斥验证&lt;/b&gt;&lt;br&gt;账户已安全归零&lt;br&gt;aiq-live 完全停机&lt;br&gt;事实保全 / 恢复 / 容量演练通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=11;" vertex="1" parent="p3-upgrade"><mxGeometry x="735" y="70" width="260" height="130" as="geometry"/></mxCell>
        <mxCell id="p3-signed-report" value="签名验证报告 / AutoIterationReport&lt;br&gt;人工：等效 runner；月度：离线 + Shadow&lt;br&gt;+ 0.10/24h + 0.50/24h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#B45309;fontSize=11;" vertex="1" parent="p3-upgrade"><mxGeometry x="385" y="250" width="260" height="76" as="geometry"/></mxCell>
        <mxCell id="p3-block" value="候选失败 → 人工 BLOCKED / 月度自动回滚&lt;br&gt;旧 champion 继续 · 本 cycle 不再晋升&lt;br&gt;quota 延期不属于候选失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#7F1D1D;fontSize=10;" vertex="1" parent="p3-upgrade"><mxGeometry x="760" y="250" width="275" height="76" as="geometry"/></mxCell>
        <mxCell id="p3-ue1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#EA580C;strokeWidth=2;" edge="1" parent="p3-upgrade" source="p3-candidate" target="p3-tempvps"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-ue2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#EA580C;strokeWidth=2;" edge="1" parent="p3-upgrade" source="p3-tempvps" target="p3-signed-report"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-ue3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#EA580C;strokeWidth=2;" edge="1" parent="p3-upgrade" source="p3-stoplive" target="p3-signed-report"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-trust" value="信任边界图例" style="swimlane;html=1;rounded=1;startSize=38;fillColor=#F8FAFC;strokeColor=#64748B;fontStyle=1;fontSize=14;" vertex="1" parent="s1"><mxGeometry x="1250" y="660" width="520" height="360" as="geometry"/></mxCell>
        <mxCell id="p3-trust-in" value="入站：仅 SSH key authentication&lt;br&gt;管理面：SSH tunnel → loopback/private" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#64748B;fontSize=11;" vertex="1" parent="p3-trust"><mxGeometry x="35" y="65" width="450" height="64" as="geometry"/></mxCell>
        <mxCell id="p3-trust-out" value="出站最小化：gateway 唯一连 Binance；Codex 仅固定 OpenAI HTTPS；通知 / SFTP / 心跳分离&lt;br&gt;Telegram 仅出站通知，不能改变交易或网络出口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#64748B;fontSize=10;" vertex="1" parent="p3-trust"><mxGeometry x="35" y="150" width="450" height="68" as="geometry"/></mxCell>
        <mxCell id="p3-trust-secret" value="密钥边界：API secret 仅 execution-service；gateway 无 secret / 不签名&lt;br&gt;研究机 / Codex / control / archive / monitoring 均不可读取" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#7F1D1D;fontSize=10;" vertex="1" parent="p3-trust"><mxGeometry x="35" y="240" width="450" height="68" as="geometry"/></mxCell>
        <mxCell id="p3-trust-rate" value="Reserve → gateway → PermitConsume(actual facts) → 唯一发送&lt;br&gt;业务零 Binance route；任一依赖故障即零新出站" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0F766E;fontColor=#134E4A;fontSize=10;" vertex="1" parent="p3-trust"><mxGeometry x="35" y="315" width="450" height="38" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
