  <diagram id="stages-trust-boundaries" name="03 阶段·信任边界">
    <mxGraphModel dx="1800" dy="1150" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="s0"/>
