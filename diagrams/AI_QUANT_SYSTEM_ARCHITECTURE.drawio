        <mxCell id="p3-host" value="首台韩国 VPS：阶段业务 project 互斥且零 Binance route；两个宿主 project 独立持久（2 vCPU / 12 GiB / 约 200 GB）" style="swimlane;html=1;rounded=1;startSize=42;fillColor=#F8FAFC;strokeColor=#334155;strokeWidth=2;fontStyle=1;fontSize=15;" vertex="1" parent="s1"><mxGeometry x="30" y="90" width="1740" height="530" as="geometry"/></mxCell>
        <mxCell id="p3-testnet" value="&lt;b&gt;aiq-testnet&lt;/b&gt;&lt;br&gt;Testnet 协议预检&lt;br&gt;独立 Testnet key/profile&lt;br&gt;零生产凭据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontSize=12;" vertex="1" parent="p3-host"><mxGeometry x="55" y="105" width="240" height="110" as="geometry"/></mxCell>
        <mxCell id="p3-seal1" value="seal · 远端验证&lt;br&gt;down · 受控退役" style="hexagon;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#78350F;fontSize=11;" vertex="1" parent="p3-host"><mxGeometry x="325" y="125" width="155" height="70" as="geometry"/></mxCell>
        <mxCell id="p3-cal" value="&lt;b&gt;aiq-calibration&lt;/b&gt;&lt;br&gt;生产公开行情连续合格 3 日&lt;br&gt;无 key · 无 execution-service&lt;br&gt;零 OrderIntent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;strokeWidth=2;fontSize=12;" vertex="1" parent="p3-host"><mxGeometry x="510" y="100" width="260" height="120" as="geometry"/></mxCell>
        <mxCell id="p3-freeze" value="远端逐对象验证&lt;br&gt;研究机优化全部 OF 参数&lt;br&gt;只生成参数候选 / 预发布素材" style="hexagon;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#B45309;fontColor=#78350F;fontSize=11;" vertex="1" parent="p3-host"><mxGeometry x="800" y="110" width="190" height="100" as="geometry"/></mxCell>
        <mxCell id="p3-validation" value="&lt;b&gt;aiq-validation · 预热后原子冻结 · 连续 ≥72h&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=34;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;fontStyle=1;fontSize=11;" vertex="1" parent="p3-host"><mxGeometry x="1020" y="65" width="360" height="200" as="geometry"/></mxCell>
        <mxCell id="p3-shadow-lane" value="Shadow lane&lt;br&gt;生产公开行情&lt;br&gt;Paper / 完整 L2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=10;" vertex="1" parent="p3-validation"><mxGeometry x="20" y="55" width="145" height="72" as="geometry"/></mxCell>
        <mxCell id="p3-test-lane" value="Testnet lane&lt;br&gt;独立规则 / DB / 队列&lt;br&gt;执行状态机验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=10;" vertex="1" parent="p3-validation"><mxGeometry x="190" y="55" width="150" height="72" as="geometry"/></mxCell>
        <mxCell id="p3-effective" value="新 DB 迁移 + 双 lane 预热 → 未来 effective_at&lt;br&gt;最终 C0 + release + 短时批准 → 原子 CHAMPION_FROZEN / GATE_TIMER_STARTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontColor=#4C1D95;fontSize=9;" vertex="1" parent="p3-validation"><mxGeometry x="25" y="140" width="310" height="48" as="geometry"/></mxCell>
        <mxCell id="p3-seal2" value="零 P0/P1 / 零差异&lt;br&gt;签名门禁 · down · 退役" style="hexagon;whiteSpace=wrap;html=1;fillColor=#FDE68A;strokeColor=#B45309;fontColor=#78350F;fontSize=11;" vertex="1" parent="p3-host"><mxGeometry x="1410" y="115" width="170" height="90" as="geometry"/></mxCell>
        <mxCell id="p3-live" value="&lt;b&gt;aiq-live&lt;/b&gt;&lt;br&gt;全新 network / volume / DB / queue&lt;br&gt;execution-service 才挂生产 key&lt;br&gt;EXPERIMENTAL_LIVE&lt;br&gt;0.10 → 人工签名 1.00" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=3;fontColor=#7F1D1D;fontSize=12;" vertex="1" parent="p3-host"><mxGeometry x="1605" y="85" width="105" height="160" as="geometry"/></mxCell>
        <mxCell id="p3-host-control" value="持久宿主 project 1 · &lt;b&gt;aiq-host-control&lt;/b&gt;（allocator + 独立 PG）" style="swimlane;html=1;rounded=1;startSize=34;fillColor=#F0FDFA;strokeColor=#0F766E;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="p3-host"><mxGeometry x="55" y="280" width="720" height="150" as="geometry"/></mxCell>
        <mxCell id="p3-rate-service" value="rate-budget-service&lt;br&gt;Reserve + PermitConsume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;strokeWidth=2;fontColor=#134E4A;fontSize=10;" vertex="1" parent="p3-host-control"><mxGeometry x="20" y="55" width="190" height="68" as="geometry"/></mxCell>
