        <mxCell id="p2-edge-rate-socket-service" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=block;startFill=1;strokeColor=#0F766E;" edge="1" parent="p2-host-control" source="p2-rate-socket" target="p2-rate-service"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p2-edge-rate-service-db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=block;startFill=1;strokeColor=#15803D;" edge="1" parent="p2-host-control" source="p2-rate-service" target="p2-rate-db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p2-edge-all-rate" value="ReserveRequest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0F766E;fontSize=9;" edge="1" parent="d1" source="p2-all" target="p2-rate-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
