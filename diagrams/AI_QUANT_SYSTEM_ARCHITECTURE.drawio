        <mxCell id="p3-rate-socket" value="rate.sock (UDS)&lt;br&gt;/run/ai-quant-rate/rate.sock&lt;br&gt;业务 Reserve；gateway Consume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;strokeWidth=2;fontColor=#0C4A6E;fontSize=10;" vertex="1" parent="p3-host-control"><mxGeometry x="465" y="47" width="230" height="84" as="geometry"/></mxCell>
        <mxCell id="p3-egress" value="持久宿主 project 2 · &lt;b&gt;aiq-binance-egress&lt;/b&gt;（唯一 Binance 网络路由）" style="swimlane;html=1;rounded=1;startSize=34;fillColor=#F0FDFA;strokeColor=#0F766E;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#134E4A;" vertex="1" parent="p3-host"><mxGeometry x="800" y="280" width="905" height="150" as="geometry"/></mxCell>
        <mxCell id="p3-rate-rule" value="唯一 binance-egress-gateway&lt;br&gt;actual facts → PermitConsume&lt;br&gt;CONSUME_GRANTED 后发送一次&lt;br&gt;无 API secret · 不签名" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#134E4A;fontSize=10;" vertex="1" parent="p3-egress"><mxGeometry x="20" y="43" width="300" height="92" as="geometry"/></mxCell>
        <mxCell id="p3-gateway-socket" value="gateway.sock (UDS)&lt;br&gt;/run/ai-quant-egress/gateway.sock&lt;br&gt;业务 request / result / inbound relay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;strokeWidth=2;fontColor=#0C4A6E;fontSize=10;" vertex="1" parent="p3-egress"><mxGeometry x="345" y="43" width="260" height="92" as="geometry"/></mxCell>
        <mxCell id="p3-rate-fail" value="allocator / DB / 任一 UDS / gateway / 业务 DB 故障&lt;br&gt;零新 Binance 出站；既有原生保护单继续" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;fontColor=#7F1D1D;fontSize=10;" vertex="1" parent="p3-egress"><mxGeometry x="630" y="43" width="250" height="92" as="geometry"/></mxCell>
        <mxCell id="p3-edge-rate-socket-service" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=block;startFill=1;strokeColor=#0F766E;" edge="1" parent="p3-host-control" source="p3-rate-socket" target="p3-rate-service"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-edge-rate-service-db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=block;startFill=1;strokeColor=#15803D;" edge="1" parent="p3-host-control" source="p3-rate-service" target="p3-rate-db"><mxGeometry relative="1" as="geometry"/></mxCell>
