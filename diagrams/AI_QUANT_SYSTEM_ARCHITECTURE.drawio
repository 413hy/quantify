        <mxCell id="p3-edge-rate-fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#DC2626;" edge="1" parent="p3-host" source="p3-rate-service" target="p3-rate-fail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-mutual" value="阶段业务 network / volume / database / queue / facts 全新且零 Binance route；业务先 Reserve，再交 gateway；只有 gateway Consume 后联网。两个宿主 project 独立持久。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;dashed=1;fontColor=#334155;fontSize=11;" vertex="1" parent="p3-host"><mxGeometry x="150" y="455" width="1440" height="48" as="geometry"/></mxCell>
        <mxCell id="p3-edge-testnet-rate" value="统一 permit 门" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;strokeColor=#0F766E;fontSize=9;" edge="1" parent="p3-host" source="p3-testnet" target="p3-rate-socket"><mxGeometry relative="1" as="geometry"/></mxCell>
