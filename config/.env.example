# 非敏感运行标识
APP_ENV=shadow
APP_CONFIG_FILE=/etc/ai-quant/system.yaml
RISK_CONFIG_FILE=/etc/ai-quant/risk.yaml
UNIVERSE_CONFIG_FILE=/etc/ai-quant/universe.yaml
PRICE_ACTION_CONFIG_FILE=/etc/ai-quant/price-action.yaml
STRATEGY_ORCHESTRATION_CONFIG_FILE=/etc/ai-quant/strategy-orchestration.yaml
AUTO_ITERATION_CONFIG_FILE=/etc/ai-quant/auto-iteration.yaml
RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
NETWORK_EGRESS_POLICY_FILE=/etc/ai-quant/network-egress.yaml
ENDPOINT_COST_CATALOG_FILE=/etc/ai-quant/host-control/binance-endpoint-cost-catalog.json
MANDATORY_ENDPOINT_INVENTORY_FILE=/etc/ai-quant/host-control/binance-mandatory-endpoint-inventory.json
BINANCE_CONNECTION_CONTRACT_FILE=/etc/ai-quant/host-control/binance-connection-contract.json
CAPABILITY_TRUST_BUNDLE_FILE=/etc/ai-quant/host-control/capability-trust-bundle.json
HOST_RATE_CONTROL_SOCKET=/run/ai-quant-rate/rate.sock
GATEWAY_IPC_SOCKET=/run/ai-quant-egress/gateway.sock
HOST_RATE_STARTUP_EVIDENCE_FILE=/run/ai-quant-rate/startup-evidence.json
LOG_LEVEL=INFO
TZ=UTC

# 连接信息不包含口令；口令必须通过只读 secret 文件挂载
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_quant
POSTGRES_USER=ai_quant_app
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD_FILE=/run/secrets/redis_password

# 交易凭据仅允许挂载到 execution-service；其他容器不得出现这些变量
BINANCE_API_KEY_FILE=/run/secrets/binance_api_key
BINANCE_API_SECRET_FILE=/run/secrets/binance_api_secret

# capability signing key 必须按服务单独注入；不得把这些路径整组挂给任一容器
RISK_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/risk_capability_signing_key
MARKET_DATA_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/market_data_capability_signing_key
CONTROL_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/control_capability_signing_key
RECONCILIATION_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/reconciliation_capability_signing_key
USER_STREAM_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/user_stream_capability_signing_key

# 通知服务凭据；通知服务没有 Binance 凭据
TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
TELEGRAM_NOTIFICATION_CHAT_IDS_FILE=/run/secrets/telegram_notification_chat_ids
FEISHU_WEBHOOK_SECRET_FILE=/run/secrets/feishu_webhook_secret
FEISHU_WEBHOOK_URL_FILE=/run/secrets/feishu_webhook_url

# 仅 codex-orchestrator 可读取；示例选用官方 ChatGPT 账户认证。若 release 改为 OPENAI_API_KEY，
# 则移除 CODEX_AUTH_STATE_DIR 并只挂载 OPENAI_API_KEY_FILE；两种认证不得同时注入。
CODEX_AUTH_MODE=CHATGPT_ACCOUNT
CODEX_AUTH_STATE_DIR=/run/secrets/codex_auth_state
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
CODEX_HOME=/var/lib/ai-quant/codex-live
CODEX_LIVE_RUN_ROOT=/var/lib/ai-quant/codex-runs/live

# 归档接收端；主机指纹必须预置，禁止自动接受未知主机
ARCHIVE_SSH_HOST=archive.example.internal
ARCHIVE_SSH_PORT=22
ARCHIVE_SSH_USER=archive_ingest
ARCHIVE_SSH_PRIVATE_KEY_FILE=/run/secrets/archive_ssh_key
ARCHIVE_SSH_KNOWN_HOSTS_FILE=/run/secrets/archive_known_hosts
ARCHIVE_AGE_RECIPIENT_FILE=/run/secrets/archive_age_recipient
ARCHIVE_AGE_RECIPIENT_SHA256=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ARCHIVE_RECEIPT_VERIFY_KEY_FILE=/run/secrets/archive_receipt_ed25519_public_key
ARCHIVE_RECEIPT_KEY_ID=replace-with-approved-archive-receipt-key-id

# 外部心跳采用 VPS 主动签名推送；不开放任何入站监控端口
HEARTBEAT_INSTANCE_ID=replace-with-non-account-instance-id
HEARTBEAT_KEY_ID=replace-with-approved-heartbeat-key-id
HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_MAX_AGE_SECONDS=120
HEARTBEAT_RECEIVER_URL_FILE=/run/secrets/heartbeat_receiver_url
HEARTBEAT_AUTH_TOKEN_FILE=/run/secrets/heartbeat_auth_token
HEARTBEAT_SIGNING_KEY_FILE=/run/secrets/heartbeat_signing_key
