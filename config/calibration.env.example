# 仅供 aiq-calibration Compose launcher 插值；无任何 Binance API key/secret
CALIBRATION_PROJECT_NAME=aiq-calibration
CALIBRATION_PROJECT_PURPOSE=CALIBRATION_3D
CALIBRATION_APP_ENV=shadow
CALIBRATION_RUNTIME_STATE=SHADOW
CALIBRATION_MARKET_SOURCE=BINANCE_PRODUCTION_PUBLIC
CALIBRATION_WS_ROUTING_CONFIG_SOURCE=SIGNED_SYSTEM_YAML
CALIBRATION_WS_ALLOWED_ROLES=PUBLIC_HIGH_FREQUENCY,MARKET_REGULAR
CALIBRATION_WS_PRIVATE_ENABLED=false
CALIBRATION_APP_CONFIG_FILE=/etc/ai-quant/calibration/system.yaml
CALIBRATION_RISK_CONFIG_FILE=/etc/ai-quant/calibration/risk.yaml
CALIBRATION_UNIVERSE_CONFIG_FILE=/etc/ai-quant/calibration/universe.yaml
CALIBRATION_PRICE_ACTION_CONFIG_FILE=/etc/ai-quant/calibration/price-action.yaml
CALIBRATION_RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
CALIBRATION_NETWORK_EGRESS_POLICY_FILE=/etc/ai-quant/calibration/network-egress.yaml
ENDPOINT_COST_CATALOG_FILE=/etc/ai-quant/host-control/binance-endpoint-cost-catalog.json
MANDATORY_ENDPOINT_INVENTORY_FILE=/etc/ai-quant/host-control/binance-mandatory-endpoint-inventory.json
BINANCE_CONNECTION_CONTRACT_FILE=/etc/ai-quant/host-control/binance-connection-contract.json
CAPABILITY_TRUST_BUNDLE_FILE=/etc/ai-quant/host-control/capability-trust-bundle.json
HOST_RATE_CONTROL_SOCKET=/run/ai-quant-rate/rate.sock
GATEWAY_IPC_SOCKET=/run/ai-quant-egress/gateway.sock
HOST_RATE_STARTUP_EVIDENCE_FILE=/run/ai-quant-rate/startup-evidence.json
CALIBRATION_POSTGRES_DB=aiq_calibration
CALIBRATION_POSTGRES_USER=aiq_calibration
CALIBRATION_POSTGRES_PASSWORD_FILE=/run/secrets/calibration_postgres_password
CALIBRATION_QUEUE_ROOT=/var/lib/ai-quant/calibration/queue
CALIBRATION_REDIS_ACL_USER=aiq_calibration
CALIBRATION_REDIS_KEY_PREFIX=calibration:
CALIBRATION_DATASET_ID=replace-with-preregistered-dataset-id
CALIBRATION_DATASET_PLAN_FILE=/etc/ai-quant/calibration/dataset-plan.yaml
CALIBRATION_DATA_QUALITY_PROFILE_FILE=/etc/ai-quant/calibration/calibration-data-quality.yaml
CALIBRATION_EXECUTION_SERVICE_ENABLED=false
CALIBRATION_ORDER_INTENT_EMISSION=DISABLED
CALIBRATION_CONTROL_MODE=READ_ONLY
