# aiq-host-control 专用非敏感 launcher 模板；不得 source 到交互 shell。
HOST_CONTROL_PROJECT=aiq-host-control
HOST_RATE_CONTROL_POSTGRES_DB=aiq_host_rate_control
HOST_RATE_CONTROL_POSTGRES_USER=aiq_host_rate_control
HOST_RATE_CONTROL_POSTGRES_PASSWORD_FILE=/run/secrets/host_rate_control_postgres_password
HOST_RATE_CONTROL_POSTGRES_DATA=/srv/ai-quant/host-control/postgres
HOST_RATE_CONTROL_SOCKET=/run/ai-quant-rate/rate.sock
HOST_STARTUP_EVIDENCE_SIGNING_KEY_FILE=/run/secrets/host_startup_evidence_signing_key
HOST_STARTUP_EVIDENCE_FILE=/run/ai-quant-attestation/host-rate-startup-evidence.json
HOST_STARTUP_EVIDENCE_REFRESH_BEFORE_EXPIRY_SECONDS=60
HOST_CONTROL_CONFIG_TRUST_ROOT_FILE=/etc/ai-quant/trust/host-control-config-keyring.json
RELEASE_SIGNING_TRUST_ROOT_FILE=/etc/ai-quant/trust/release-signing-keyring.json
GATEWAY_IPC_SOCKET=/run/ai-quant-egress/gateway.sock
GATEWAY_IPC_MAX_FRAME_BYTES=16777216
GATEWAY_IPC_MAX_DECODED_PAYLOAD_BYTES=12582912
GATEWAY_IPC_BACKLOG=128
GATEWAY_IPC_PER_CALLER_QUEUE=32
RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
ENDPOINT_COST_CATALOG_FILE=/etc/ai-quant/host-control/binance-endpoint-cost-catalog.json
MANDATORY_ENDPOINT_INVENTORY_FILE=/etc/ai-quant/host-control/binance-mandatory-endpoint-inventory.json
BINANCE_CONNECTION_CONTRACT_FILE=/etc/ai-quant/host-control/binance-connection-contract.json
CAPABILITY_TRUST_BUNDLE_FILE=/etc/ai-quant/host-control/capability-trust-bundle.json
NETWORK_EGRESS_POLICY_FILE=/etc/ai-quant/host-control/network-egress.yaml
HOST_BOOTSTRAP_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/host_bootstrap_capability_signing_key
HOST_RATE_MIGRATION_HEAD=<HOST_RATE_MIGRATION_HEAD>
HOST_RATE_STARTUP_EVIDENCE_DIR=/srv/ai-quant/evidence/host-control
