{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quant.local/config/binance-mandatory-endpoint-inventory.schema.json",
  "title": "V1 Mandatory Binance Endpoint Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "inventory_hash", "content", "signature"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "inventory_hash": { "$ref": "#/$defs/sha256" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventory_id", "inventory_status", "issued_at", "valid_until", "mandatory_endpoint_groups", "ws_api_enabled_v1", "catalog_required_status", "catalog_coverage_rule", "unsupported_in_environment_action", "missing_action"],
      "properties": {
        "inventory_id": { "$ref": "#/$defs/id" },
        "inventory_status": { "enum": ["UNVALIDATED_ENGINEERING_BASELINE", "SIGNED_RUNTIME"] },
        "issued_at": { "type": "string", "format": "date-time" },
        "valid_until": { "type": "string", "format": "date-time" },
        "mandatory_endpoint_groups": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fapi", "fstream"],
          "properties": {
            "fapi": { "const": [
              "REST_SERVER_TIME", "REST_UM_EXCHANGE_INFO", "REST_ORDER_BOOK_SNAPSHOT",
              "REST_LISTEN_KEY_CREATE", "REST_LISTEN_KEY_KEEPALIVE", "REST_LISTEN_KEY_CLOSE",
              "REST_POSITION_MODE_QUERY", "REST_POSITION_RISK_QUERY", "REST_ACCOUNT_QUERY", "REST_ACCOUNT_TRADES_QUERY", "REST_INCOME_HISTORY_QUERY", "REST_LEVERAGE_BRACKET_QUERY",
              "REST_OPEN_ORDERS_QUERY", "REST_ORDER_QUERY", "REST_NEW_ORDER", "REST_CANCEL_ORDER",
              "REST_NEW_ALGO_ORDER", "REST_QUERY_ALGO_ORDER", "REST_CANCEL_ALGO_ORDER", "REST_OPEN_ALGO_ORDERS"
            ] },
            "fstream": { "const": [
              "MARKET_STREAM_CONNECT_PUBLIC", "MARKET_STREAM_CONNECT_MARKET", "MARKET_STREAM_CONNECT_PRIVATE",
              "MARKET_STREAM_JSON_SUBSCRIBE", "MARKET_STREAM_JSON_UNSUBSCRIBE", "MARKET_STREAM_PING", "MARKET_STREAM_PONG"
            ] }
          }
        },
        "ws_api_enabled_v1": { "const": false },
        "catalog_required_status": { "const": "SIGNED_RUNTIME" },
        "catalog_coverage_rule": { "const": "EVERY_GROUP_ID_EXACTLY_ONE_CONTRACT_PER_ENABLED_APPLICABLE_AUTHORITY_WITH_FRESH_CLOSED_SOURCE_AND_COST_RULE" },
        "unsupported_in_environment_action": { "const": "BLOCK_STAGE_AND_REQUIRE_SIGNED_PROBE_EVIDENCE_NO_SILENT_OMISSION" },
        "missing_action": { "const": "BLOCK_ALL_NEW_BINANCE_EGRESS_AND_OPEN_P0" }
      }
    },
    "signature": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "key_id", "signed_at", "signature_base64"],
          "properties": {
            "algorithm": { "const": "Ed25519" },
            "key_id": { "$ref": "#/$defs/id" },
            "signed_at": { "type": "string", "format": "date-time" },
            "signature_base64": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "content": { "properties": { "inventory_status": { "const": "SIGNED_RUNTIME" } }, "required": ["inventory_status"] } }, "required": ["content"] },
      "then": { "properties": { "signature": { "type": "object" } } },
      "else": { "properties": { "signature": { "type": "null" } } }
    }
  ],
  "$comment": "inventory_hash=SHA-256(RFC8785 JCS(content))。fapi 组只映射适用的 FAPI authority，fstream 组只映射适用的 FSTREAM authority，不允许把 REST 契约机械复制到 stream authority。Testnet 若缺任一强制 endpoint，必须阻断该阶段并提交签名 probe evidence，禁止静默删项。示例 baseline 永不允许运行。",
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{8,128}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
