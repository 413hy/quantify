# binance-egress-gateway 独立项目；禁止放置 Binance API secret、capability 私钥或数据库凭据。
APP_ENV=production
GATEWAY_IPC_SOCKET=/run/ai-quant-egress/gateway.sock
HOST_RATE_CONTROL_SOCKET=/run/ai-quant-rate/rate.sock
HOST_RATE_STARTUP_EVIDENCE_FILE=/run/ai-quant-attestation/host-rate-startup-evidence.json
# gateway 不读取 config 私钥；只读 trust root 用于独立复验已签快照和 startup evidence。
HOST_CONTROL_CONFIG_TRUST_ROOT_FILE=/etc/ai-quant/trust/host-control-config-keyring.json
RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
BINANCE_ENDPOINT_COST_CATALOG_FILE=/etc/ai-quant/host-control/binance-endpoint-cost-catalog.json
BINANCE_MANDATORY_ENDPOINT_INVENTORY_FILE=/etc/ai-quant/host-control/binance-mandatory-endpoint-inventory.json
BINANCE_CONNECTION_CONTRACT_FILE=/etc/ai-quant/host-control/binance-connection-contract.json
CAPABILITY_TRUST_BUNDLE_FILE=/etc/ai-quant/host-control/capability-trust-bundle.json
NETWORK_EGRESS_POLICY_FILE=/etc/ai-quant/host-control/network-egress.yaml
GATEWAY_UID=11005
GATEWAY_GID=11005
GATEWAY_SOCKET_MODE=0660
# 外层 JSON/IPC frame 最大 16 MiB；base64 解码后的单个 Binance payload 最大 12 MiB，留足编码和信封开销。
GATEWAY_MAX_FRAME_BYTES=16777216
GATEWAY_MAX_DECODED_PAYLOAD_BYTES=12582912
GATEWAY_MAX_PENDING_REQUESTS=256
GATEWAY_MAX_CONNECTIONS_PER_AUTHORITY=8
GATEWAY_TCP_IPC_FALLBACK_ENABLED=false
GATEWAY_ONLY_BINANCE_EGRESS=true
GATEWAY_LOG_SENSITIVE_FIELDS=false
