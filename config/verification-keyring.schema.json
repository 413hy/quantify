{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quant.local/config/verification-keyring.schema.json",
  "title": "Root Provisioned Verification Keyring",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "keyring_hash", "content", "rotation_proof"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "keyring_hash": { "$ref": "#/$defs/sha256" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyring_id", "purpose", "provisioning", "keys", "revoked_key_ids", "unknown_key_action"],
      "properties": {
        "keyring_id": { "$ref": "#/$defs/id" },
        "purpose": { "enum": ["HOST_CONTROL_CONFIG", "RELEASE_MANIFEST", "OWNER_APPROVAL", "RESEARCH_APPROVAL"] },
        "provisioning": { "const": "ROOT_OWNED_0444_OUT_OF_BAND_PINNED_SHA256_NOT_RELEASE_WRITABLE" },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key_id", "public_key_base64", "status", "not_before", "not_after"],
            "properties": {
              "key_id": { "$ref": "#/$defs/id" },
              "public_key_base64": { "type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$" },
              "status": { "enum": ["CURRENT", "NEXT", "RETIRED"] },
              "not_before": { "type": "string", "format": "date-time" },
              "not_after": { "type": "string", "format": "date-time" }
            }
          }
        },
        "revoked_key_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "unknown_key_action": { "const": "DENY_AND_OPEN_P0" }
      }
    },
    "rotation_proof": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["old_key_id", "new_key_id", "overlap_seconds", "old_signature_base64", "new_signature_base64"],
          "properties": {
            "old_key_id": { "$ref": "#/$defs/id" },
            "new_key_id": { "$ref": "#/$defs/id" },
            "overlap_seconds": { "type": "integer", "minimum": 3600, "maximum": 604800 },
            "old_signature_base64": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" },
            "new_signature_base64": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" }
          }
        }
      ]
    }
  },
  "$comment": "keyring_hash=SHA-256(RFC8785 JCS(content))。首次安装必须由操作员通过独立控制台比对 fingerprint；release 不能修改该文件。轮换必须 CURRENT 与 NEXT 双签新 content 并保持 overlap；撤销立即优先于 not_after。各 purpose 使用不同 keyring/私钥，私钥始终离线。",
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{8,128}$" }
  }
}
