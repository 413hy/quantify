# 仅由 aiq-validation Compose launcher 用于 Compose 插值；禁止把整份文件注入容器
VALIDATION_PROJECT_NAME=aiq-validation
VALIDATION_NETWORK_EGRESS_POLICY_FILE=/etc/ai-quant/validation/network-egress.yaml
ENDPOINT_COST_CATALOG_FILE=/etc/ai-quant/host-control/binance-endpoint-cost-catalog.json
MANDATORY_ENDPOINT_INVENTORY_FILE=/etc/ai-quant/host-control/binance-mandatory-endpoint-inventory.json
BINANCE_CONNECTION_CONTRACT_FILE=/etc/ai-quant/host-control/binance-connection-contract.json
CAPABILITY_TRUST_BUNDLE_FILE=/etc/ai-quant/host-control/capability-trust-bundle.json
HOST_RATE_CONTROL_SOCKET=/run/ai-quant-rate/rate.sock
GATEWAY_IPC_SOCKET=/run/ai-quant-egress/gateway.sock
HOST_RATE_STARTUP_EVIDENCE_FILE=/run/ai-quant-rate/startup-evidence.json

SHADOW_APP_ENV=shadow
SHADOW_APP_CONFIG_FILE=/etc/ai-quant/validation/shadow/system.yaml
SHADOW_RISK_CONFIG_FILE=/etc/ai-quant/validation/shadow/risk.yaml
SHADOW_UNIVERSE_CONFIG_FILE=/etc/ai-quant/validation/shadow/universe.yaml
SHADOW_PRICE_ACTION_CONFIG_FILE=/etc/ai-quant/validation/shadow/price-action.yaml
SHADOW_RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
SHADOW_POSTGRES_DB=aiq_shadow
SHADOW_POSTGRES_USER=aiq_shadow
SHADOW_POSTGRES_PASSWORD_FILE=/run/secrets/shadow_postgres_password
SHADOW_QUEUE_ROOT=/var/lib/ai-quant/validation/shadow/queue
SHADOW_ORDER_PREFIX=s
SHADOW_REDIS_ACL_USER=aiq_shadow
SHADOW_REDIS_KEY_PREFIX=shadow:
SHADOW_MARKET_SOURCE=BINANCE_PRODUCTION_PUBLIC
SHADOW_WS_ROUTING_CONFIG_SOURCE=SIGNED_SYSTEM_YAML
SHADOW_WS_ALLOWED_ROLES=PUBLIC_HIGH_FREQUENCY,MARKET_REGULAR
SHADOW_WS_PRIVATE_ENABLED=false

TESTNET_APP_ENV=testnet
TESTNET_APP_CONFIG_FILE=/etc/ai-quant/validation/testnet/system.yaml
TESTNET_RISK_CONFIG_FILE=/etc/ai-quant/validation/testnet/risk.yaml
TESTNET_UNIVERSE_CONFIG_FILE=/etc/ai-quant/validation/testnet/universe.yaml
TESTNET_PRICE_ACTION_CONFIG_FILE=/etc/ai-quant/validation/testnet/price-action.yaml
TESTNET_RATE_BUDGET_CONFIG_FILE=/etc/ai-quant/host-control/rate-budget.yaml
TESTNET_POSTGRES_DB=aiq_testnet
TESTNET_POSTGRES_USER=aiq_testnet
TESTNET_POSTGRES_PASSWORD_FILE=/run/secrets/testnet_postgres_password
TESTNET_QUEUE_ROOT=/var/lib/ai-quant/validation/testnet/queue
TESTNET_ORDER_PREFIX=t
TESTNET_REDIS_ACL_USER=aiq_testnet
TESTNET_REDIS_KEY_PREFIX=testnet:
TESTNET_MARKET_SOURCE=BINANCE_TESTNET
TESTNET_WS_ROUTING_CONFIG_SOURCE=SIGNED_SYSTEM_YAML
TESTNET_WS_ALLOWED_ROLES=PUBLIC_HIGH_FREQUENCY,MARKET_REGULAR,PRIVATE_USER_DATA
TESTNET_WS_PRIVATE_ENABLED=true
TESTNET_PROTOCOL_PROBE_PLAN_FILE=/etc/ai-quant/validation/testnet/testnet-protocol-probe-plan.json
TESTNET_BINANCE_API_KEY_FILE=/run/secrets/binance_testnet_api_key
TESTNET_BINANCE_API_SECRET_FILE=/run/secrets/binance_testnet_api_secret
TESTNET_CAPABILITY_SIGNING_KEY_FILE=/run/secrets/testnet_probe_capability_signing_key
