{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engineering-proposal.schema.json",
  "title": "EngineeringProposal",
  "description": "月度 Codex 对禁止自动发布领域提出的只读工程建议；永远不能被自动发布器消费。proposal_hash=SHA-256(RFC8785 JCS(content))。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "proposal_hash", "content"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "proposal_hash": { "$ref": "#/$defs/sha256" },
    "content": {
      "type": "object", "additionalProperties": false,
      "required": ["proposal_id", "iteration_cycle_id", "created_at", "category", "title", "problem", "evidence_refs", "suggested_change", "affected_components", "risk", "validation_plan", "auto_publish_allowed", "required_human_path"],
      "properties": {
        "proposal_id": { "$ref": "#/$defs/id" },
        "iteration_cycle_id": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$" },
        "created_at": { "type": "string", "format": "date-time" },
        "category": { "enum": ["HARD_RISK", "EXECUTION_CODE", "ORDER_STATE_MACHINE", "TOOL_ALLOWLIST", "NETWORK", "DATABASE", "CONTAINER_INFRA", "SECRET", "NEW_STRATEGY_TYPE", "OTHER_ENGINEERING"] },
        "title": { "type": "string", "minLength": 5, "maxLength": 160 },
        "problem": { "type": "string", "minLength": 20, "maxLength": 4000 },
        "evidence_refs": { "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "minLength": 8, "maxLength": 240 } },
        "suggested_change": { "type": "string", "minLength": 20, "maxLength": 8000 },
        "affected_components": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,100}$" } },
        "risk": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "validation_plan": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "type": "string", "minLength": 5, "maxLength": 500 } },
        "auto_publish_allowed": { "const": false },
        "required_human_path": { "const": "C3_OR_C4_ENGINEERING_REVIEW" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|[0-9A-HJKMNP-TV-Z]{26})$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
