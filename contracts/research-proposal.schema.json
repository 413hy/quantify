{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quant.local/contracts/research-proposal.schema.json",
  "title": "Immutable Codex Research Proposal",
  "description": "离线 Codex 生成的不可变研究提案。proposal_hash=SHA-256(RFC 8785 JCS(content))；Codex 只能提交 PENDING_HUMAN_REVIEW，人工结论使用独立 review 记录。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "proposal_hash", "content"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "proposal_hash": { "$ref": "#/$defs/sha256" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposal_id", "created_at", "author_agent", "base_strategy_package_id", "base_strategy_package_hash", "hypothesis", "evidence_sources", "change_set", "data_boundaries", "evaluation_stage", "evaluation_plan", "results", "risks", "review_status", "auto_publish_allowed"],
      "properties": {
        "proposal_id": { "$ref": "#/$defs/id" },
        "created_at": { "type": "string", "format": "date-time" },
        "author_agent": { "type": "string", "minLength": 1, "maxLength": 120 },
        "base_strategy_package_id": { "$ref": "#/$defs/id" },
        "base_strategy_package_hash": { "$ref": "#/$defs/sha256" },
        "hypothesis": { "type": "string", "minLength": 20, "maxLength": 4000 },
        "evidence_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "kind", "uri", "sha256", "accessed_at", "evidence_grade"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1, "maxLength": 100 },
              "kind": { "enum": ["OFFICIAL_DOC", "RAW_DATA", "DERIVED_DATA", "BACKTEST", "INCIDENT", "REFERENCE_METHOD"] },
              "uri": { "type": "string", "minLength": 1, "maxLength": 1000 },
              "sha256": { "$ref": "#/$defs/sha256" },
              "accessed_at": { "type": "string", "format": "date-time" },
              "evidence_grade": { "enum": ["AUTHORITATIVE", "OBSERVED", "DERIVED", "REFERENCE_ONLY"] }
            }
          }
        },
        "change_set": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "before_hash", "after_hash", "rationale"],
            "properties": {
              "path": { "$ref": "#/$defs/safeRelativePath" },
              "before_hash": { "$ref": "#/$defs/sha256" },
              "after_hash": { "$ref": "#/$defs/sha256" },
              "rationale": { "type": "string", "minLength": 10, "maxLength": 1000 }
            }
          }
        },
        "data_boundaries": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seen_until", "champion_oos_start", "champion_oos_end", "champion_oos_accessed", "manifest_hashes"],
          "properties": {
            "seen_until": { "type": "string", "format": "date-time" },
            "champion_oos_start": { "type": "string", "format": "date-time" },
            "champion_oos_end": { "type": "string", "format": "date-time" },
            "champion_oos_accessed": { "const": false },
            "manifest_hashes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/sha256" } }
          }
        },
        "evaluation_stage": { "const": "CHALLENGER" },
        "evaluation_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runs", "parameter_perturbation_pct", "minimum_trades", "promotion_metrics"],
          "properties": {
            "runs": {
              "type": "array",
              "minItems": 3,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/evaluationRun" },
              "allOf": [
                { "type": "array", "contains": { "type": "object", "properties": { "scenario": { "const": "BASELINE_COST_1_0" } }, "required": ["scenario"] } },
                { "type": "array", "contains": { "type": "object", "properties": { "scenario": { "const": "COST_STRESS_1_5" } }, "required": ["scenario"] } },
                { "type": "array", "contains": { "type": "object", "properties": { "scenario": { "const": "PARAMETER_PERTURBATION_20" } }, "required": ["scenario"] } }
              ]
            },
            "parameter_perturbation_pct": { "const": 20 },
            "minimum_trades": { "type": "integer", "minimum": 1 },
            "promotion_metrics": {
              "type": "array",
              "minItems": 6,
              "maxItems": 6,
              "uniqueItems": true,
              "items": { "enum": ["NET_EXPECTANCY", "PROFIT_FACTOR", "MAX_DRAWDOWN", "COST_STRESS", "PARAMETER_STABILITY", "SYMBOL_CONCENTRATION"] },
              "allOf": [
                { "contains": { "const": "NET_EXPECTANCY" } },
                { "contains": { "const": "PROFIT_FACTOR" } },
                { "contains": { "const": "MAX_DRAWDOWN" } },
                { "contains": { "const": "COST_STRESS" } },
                { "contains": { "const": "PARAMETER_STABILITY" } },
                { "contains": { "const": "SYMBOL_CONCENTRATION" } }
              ]
            }
          }
        },
        "results": {
          "type": "object",
          "additionalProperties": false,
          "required": ["available", "metrics", "report_hash"],
          "properties": {
            "available": { "const": true },
            "metrics": {
              "type": "object",
              "additionalProperties": false,
              "required": ["trade_count", "net_expectancy", "profit_factor_defined", "profit_factor", "max_drawdown_pct", "stressed_net_expectancy_1_5x", "parameter_stability_pass", "symbol_concentration_pass", "max_positive_contribution_share_pct"],
              "properties": {
                "trade_count": { "type": "integer", "minimum": 0 },
                "net_expectancy": { "$ref": "#/$defs/decimal" },
                "profit_factor_defined": { "type": "boolean" },
                "profit_factor": { "oneOf": [{ "$ref": "#/$defs/nonNegativeDecimal" }, { "type": "null" }] },
                "max_drawdown_pct": { "$ref": "#/$defs/nonNegativeDecimal" },
                "stressed_net_expectancy_1_5x": { "$ref": "#/$defs/decimal" },
                "parameter_stability_pass": { "type": "boolean" },
                "symbol_concentration_pass": { "type": "boolean" },
                "max_positive_contribution_share_pct": { "$ref": "#/$defs/nonNegativeDecimal" }
              },
              "allOf": [
                {
                  "if": { "properties": { "profit_factor_defined": { "const": true } }, "required": ["profit_factor_defined"] },
                  "then": { "properties": { "profit_factor": { "$ref": "#/$defs/nonNegativeDecimal" } } },
                  "else": { "properties": { "profit_factor": { "type": "null" } } }
                }
              ]
            },
            "report_hash": { "$ref": "#/$defs/sha256" }
          }
        },
        "risks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 10, "maxLength": 1000 } },
        "review_status": { "const": "PENDING_HUMAN_REVIEW" },
        "auto_publish_allowed": { "const": false }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|[0-9A-HJKMNP-TV-Z]{26})$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decimal": { "type": "string", "pattern": "^-?(?:0|[1-9][0-9]{0,19})(?:\\.[0-9]{1,18})?$" },
    "nonNegativeDecimal": { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})(?:\\.[0-9]{1,18})?$" },
    "safeRelativePath": { "type": "string", "minLength": 1, "maxLength": 300, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$" },
    "evaluationRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "scenario", "run_manifest_hash", "replay_hash", "metrics_hash"],
      "properties": {
        "run_id": { "$ref": "#/$defs/id" },
        "scenario": { "enum": ["BASELINE_COST_1_0", "COST_STRESS_1_5", "PARAMETER_PERTURBATION_20"] },
        "run_manifest_hash": { "$ref": "#/$defs/sha256" },
        "replay_hash": { "$ref": "#/$defs/sha256" },
        "metrics_hash": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
